# TengeGuard real Gmail access
# Users never see or enter these keys. They are configured once on the TengeGuard server.

# Public URL of the running app. For local dev use http://localhost:3001 if Next selected port 3001.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth / Gmail read-only connector.
# Same value as GOOGLE_CLIENT_ID. This one is safe to expose to the browser for Google Identity Services.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Google Cloud Console redirect URI must match:
# http://localhost:3000/api/subcut/gmail/callback
# or your production URL:
# https://your-domain.com/api/subcut/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Gmail scan scale. Increase on the server if you have many users or very large mailboxes.
TENGEGUARD_GMAIL_MAX_PER_QUERY=250
TENGEGUARD_GMAIL_MAX_MESSAGES=3000

# Telegram bot notifications.
# Create a bot in BotFather with display name "TengeGuard".
# Bot username must end with "bot", for example TengeGuardBot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=TengeGuardBot
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_LINK_SECRET=
TENGEGUARD_CRON_SECRET=
TENGEGUARD_ADMIN_SECRET=

# AI chat assistant.
# Server-side only. Do not expose this key in the browser.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Future connectors. Keep server-side only.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=

# Automatic bank consent. This must be an official Open Banking / bank-data provider URL.
TENGEGUARD_BANK_PROVIDER=Salt Edge
TENGEGUARD_BANK_PROVIDER_URL=https://www.saltedge.com/api/v6
TENGEGUARD_BANK_PROVIDER_KEY=
TENGEGUARD_BANK_PROVIDER_SECRET=
TENGEGUARD_BANK_CONNECT_URL=
SALTEDGE_APP_ID=
SALTEDGE_SECRET=

APPLE_ISSUER_ID=
APPLE_KEY_ID=
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
TENGEGUARD_STORE_CONNECT_URL=

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
STRIPE_SECRET_KEY=
TENGEGUARD_WALLET_CONNECT_URL=
